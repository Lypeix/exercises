usage = {
    "electricity": 120,   # kWh
    "water": 30,          # cubic meters
    "gas": 50             # units
}

rates = {
    "electricity": 0.75,  # per kWh
    "water": 2.10,        # per unit
    "gas": 1.40           # per unit
}

TAX_RATE = 0.20

def compute_subtotals(usage, rates):
    result = {} 

    for key, qty in usage.items(): 
        result[key] = qty * rates[key] 

    return result 

def compute_final_bill(usage, rates):

    subtotals = compute_subtotals(usage, rates)
    

    for key, qty in usage.items():
        subtotals[key] = qty * rates[key] 

    return subtotals

def print_subtotals(usage, rates):

    subtotals = compute_final_bill(usage, rates)  

    subtotal_sum = 0 


    for key, value in subtotals.items(): 
        subtotal_sum += subtotals[key] 
        print(f"subtotals: {key}: {value}")
        
    tax_amount = subtotal_sum * TAX_RATE
    total = subtotal_sum + tax_amount    


    print(f"subtotal_sum: {subtotal_sum}")
    print(f"tax: {TAX_RATE}")
    print(f"total: {round(total, 2)}")


print_subtotals(usage, rates)
