usage = {
    "electricity": 120,   # kWh
    "water": 30,          # cubic meters
    "gas": 50             # units
}

rates = {
    "electricity": 0.75,  # per kWh
    "water": 2.10,        # per unit
    "gas": 1.40           # per unit
}

TAX_RATE = 0.20
tax_rate = TAX_RATE

def compute_subtotals(usage, rates):
    result = {} # creates dictionary to store the data in

    for key, qty in usage.items():  # iterates over each key and its value in the usage dict
        result[key] = qty * rates[key] # result for each key = it's quantity multiplied by the quantity of the same keys in rates

    return result # saves the result to be passed down to other function

def compute_final_bill(usage, rates, tax_rate):

    subtotals = compute_subtotals(usage, rates) # uses the data passed down from previous function to define the subtotal variable
    tax_rate = TAX_RATE # assigns parameter to the constant

    for key, qty in usage.items(): # iterates over key and its value in the subtotal variable (which acts as result dict from the function it calls)
        subtotals[key] = qty 

    return subtotals

def print_subtotals(usage, rates, tax_rate): 

    subtotals = compute_final_bill(usage, rates, tax_rate)  

    subtotal_sum = 0 # accumulates value


    for key, value in subtotals.items(): 
        subtotal_sum += subtotals[key] # adds value to the accumulator
        print(f"subtotals: {key}: {value}")
        
    tax_amount = subtotal_sum * TAX_RATE # calculates the tax
    total = subtotal_sum + tax_amount # adds the tax amount to the subtotal_sum and assigns it to a variable


    print(f"subtotal_sum: {subtotal_sum}")
    print(f"tax: {TAX_RATE}")
    print(f"total: {round(total, 2)}")




print_subtotals(usage, rates, tax_rate)
