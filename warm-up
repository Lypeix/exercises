items = ['cola', 'manga', 'suit']

def build_menu(items):
    lines = []
    
    for i in range(0, len(items)):
        lines.append(f"{i + 1}. {items[i]}")
    lines.append("> ")
    
    return "\n"

build_menu(items)

products = {
    "cola": {"name": "Cola", "price": 4},
    "mango": {"name": "Mango", "price": 8}
}

def print_prices(products):

    product_keys = list(products.keys())

    for idx, key in enumerate(product_keys, start=1):
        product = products[key]
        qty = product['price']

        print(f"{idx}. {product['name']} = {qty}")

print_prices(products)

keys = ["cola", "mango", "suit"]
choice = "2"

def user_choice(prompt, valid_choices):
    while True:
        choice = input(prompt)

        if choice in valid_choices:
            return choice
        else:
            print(f"Invalid choice! Choose from: {', '.join(valid_choices)}")

def display_cart(keys):

    lines = ["Which item would you like to choose?"]

    for idx, key in enumerate(keys, start=1):
        lines.append(f"{idx}. {key}")
    
    lines.append("> ")

    return "\n".join(lines)

def add_to_cart(keys):

    prompt = display_cart(keys)

    valid_choices = [str(i) for i in range(1, len(keys) + 1)]

    choice_num = user_choice(prompt, valid_choices)

    choice = int(choice_num) - 1

    product = keys[choice]

    print(f"You have chosen {product}!")

    return


add_to_cart(keys)