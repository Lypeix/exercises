class Expense:
    def __init__(self, name, amount, category, data):
        self.name = name
        self.amount = amount
        self.category = category
        self.data = data

class ExpenseTracker:
    def __init__(self):
        self.expenses = []

    def expense_add(self, expense):
        self.expenses.append(expense)

    def get_total_spent(self, expense):
        total = 0

        for expense in self.expenses:
            total += expense.amount
        
        return total
