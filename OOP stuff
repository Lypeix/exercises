class Activity: # Blueprint / architect
    def __init__(self, name, date, type): # builder that runs automaticaly whenever new activity object is made, meanwhile first variable in the () is referring to the particular object that's currently being initialized
        self.name = name # equivalent of product['name'] = name
        self.date = date
        self.type = type


class ActivityTracker:
    def __init__(self):
        self.activities = [] # creates a list to store variables in

    def add_activities(self, activities):
        self.activities.append(activities) # adds activity objects to the list

    tracker = ActivityTracker() # Creates ActivityTracker object with empty activities list

activity_1 = Activity("Gym", "03.07.2026", "Fitness")
activity_2 = Activity("Parachute Jumping", "01.07.2026", "Entertainment")
activity_3 = Activity("Dark Souls", "02.07.2026", "Relaxation")
activity_4 = Activity("Shopping", "03.07.2026", "Entertainment")

tracker.add_activities(activity_1) # adds activity_1 to the tracker
tracker.add_activities(activity_2)
tracker.add_activities(activity_3)
tracker.add_activities(activity_4)

for activity in tracker.activities: # iterates over each item in the tracker variable
    print(f"Name: {activity.name} -- Date: {activity.date} -- Type: {activity.type}")
