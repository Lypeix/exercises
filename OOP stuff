class Activity:
    def __init__(self, name, energy, category, date):
        self.name = name
        self.energy = energy
        self.category = category
        self.date = date
        


class ActivityTracker:
    def __init__(self):
        self.activities = []

    def add_activity(self, activity):
        self.activities.append(activity)

    def get_total_energy_spent(self):   
        total_energy = 0
        
        for activity in self.activities:
            total_energy += activity.energy

        return total_energy

def user_choice(prompt, valid_choices):
    while True:
        choice = input(prompt)
        if choice in valid_choices:
            return choice
        else:
            print(f"Invalid choice! Choose from {', '.join(valid_choices)}")

def get_integer(prompt):
    while True:
        try:
            value = int(input(prompt))

            if value <= 0:
                print("The value must be greater than 0!")       
            else:
                return value
        
        except ValueError:
            print("Invalid number!")
 
def create_activity():
    name = input("Name: ")
    energy = get_integer("Energy: ")
    category = input("Category: ")
    date = input("Date: ")

    return Activity(name, energy, category, date)

def initialize():
    tracker = ActivityTracker()
    
    while True:

        answer =  user_choice("What would you like to do?"
                            "\n1. Add a new activity"
                            "\n2. View current activities"
                            "\n3. View total energy required"
                            "\n4. Exit"            
                            "\n> ",
                            ["1", "2", "3", "4"]       
                            )
        
        if answer == "1":
            activity = create_activity()
            tracker.add_activity(activity)

        elif answer == "2":
            if len(tracker.activities) == 0:
                print("You have no activities")
            else:
                for activity in tracker.activities:
                    print(f"Name: {activity.name} -- Energy Required: {activity.energy} -- Category: {activity.category} -- Date: {activity.date}")

        elif answer == "3":
            print(f"Total energy: {tracker.get_total_energy_spent()}")

        elif answer == "4":
            break



initialize()
