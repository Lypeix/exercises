class Activity: # blueprint
    def __init__(self, name, energy, category, date): # constructor, first paremeter means "initialize this particular object", runs whenever a new object is created
        self.name = name
        self.energy = energy
        self.category = category
        self.date = date
        


class ActivityTracker:
    def __init__(self):
        self.activities = [] # creats empety list to store values in

    def add_activity(self, activity):
        self.activities.append(activity) # adds object to the list

    def get_total_energy_spent(self):   
        total_energy = 0 # accumulator
        
        for activity in self.activities: # for each object in the list 
            total_energy += activity.energy # add it's energy value to the accumulator

        return total_energy

def user_choice(prompt, valid_choices):
    while True:
        choice = input(prompt).strip().lower()
        if choice in valid_choices:
            return choice
        else:
            print(f"Invalid choice! Choose from {', '.join(valid_choices)}")

def get_integer(prompt): # function's purpose is to make sure user always puts an integer value in the question about energy so that total_energy can be calculated correctly
    while True:
        try:
            value = int(input(prompt))

            if value <= 0:
                print("The value must be greater than 0!")       
            else:
                return value
        
        except ValueError:
            print("Invalid number!")
 
def create_activity():
    name = input("Name: ")
    energy = get_integer("Energy: ")
    category = input("Category: ")
    date = input("Date: ")

    return Activity(name, energy, category, date) # return expense data to the rest of the program using Activity blueprint (class)

def initialize():
    tracker = ActivityTracker() # creates an object with empty list and allows easier usage of the functions that are inside ActivityTracker
    
    while True:

        answer =  user_choice("What would you like to do?"
                            "\n1. Add a new activity"
                            "\n2. View current activities"
                            "\n3. View total energy required"
                            "\n4. Exit"            
                            "\n> ",
                            ["1", "2", "3", "4"]       
                            )
        
        if answer == "1":
            activity = create_activity()
            tracker.add_activity(activity) # tracker is an ActivityTracker object, so it can use add_activity method

        elif answer == "2":
            if len(tracker.activities) == 0: # if the list has no objects, it's length is zero, so if there arent characters, it wont run
                print("You have no activities")
            else:
                for activity in tracker.activities:
                    print(f"Name: {activity.name} -- Energy Required: {activity.energy} -- Category: {activity.category} -- Date: {activity.date}")

        elif answer == "3":
            print(f"Total energy: {tracker.get_total_energy_spent()}")

        elif answer == "4":
            break



initialize()

