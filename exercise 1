letters = ["a", "b", "c", "d"]

def user_choice(prompt, valid_choices):
    while True:
        choice = input(prompt)

        if choice in valid_choices:
            return choice
        else:
            print(f"Invalid choice, please choose one of the following {', '.join(valid_choices)}")


def letter_show():
    prompt_lines = ["Which letter would you like to devour?"]

    for idx, key in enumerate(letters, start=1):
        prompt_lines.append(f"{idx}. {key}")

    prompt_lines.append("> ")

    return "\n".join(prompt_lines)

def letter_add():

    prompt = letter_show()

    valid_choices = [str(i) for i in range(1, len(letters) + 1)]

    choice_num = user_choice(prompt, valid_choices)

    letter = letters[int(choice_num) - 1]

    print(letter)

letter_add()